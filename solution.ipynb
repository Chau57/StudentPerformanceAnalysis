     ]
    }
   ],
   "source": [
    "# Huấn luyện lại mô hình best_feature_model với đặc trưng tốt nhất trên toàn bộ tập huấn luyện\n",
    "best_feature_model = np.argmin(mae_per_feature)\n",
    "X_train_model = X_train.values[:,best_feature_model].reshape((-1,1))\n",
    "\n",
    "one1 = np.ones((X_train_model.shape[0],1))\n",
    "Xbar_model = np.concatenate((one1, X_train_model), axis = 1)\n",
    "w_model = LinearRegression(Xbar_model,y_train)\n",
    "\n",
    "express = f\"{np.round(w_model[0],3)} + \" + \" + \" f\"{np.round(w_model[1],3)} * {features[best_feature_model]}\"\n",
    "\n",
    "print(\"Biểu thức hồi quy tuyến tính:\")\n",
    "print(\"y_hat =\", express)\n"
   ]
  },
