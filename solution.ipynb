   "source": [
    "# Yêu cầu 2b: Xây dựng mô hình sử dụng duy nhất 1 đặc trưng, tìm mô hình cho kết quả tốt nhất (2 điểm)"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "Lưu ý: Khi sử dụng cross-validation, sinh viên cần xáo trộn dữ liệu 1 lần duy nhất và thực hiện trên toàn bộ đặc trưng"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 7,
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Feature                                    MAE\n",
      "Hours Studied                      \t    15.449\n",
      "Previous Scores                    \t     6.618\n",
      "Extracurricular Activities         \t    16.196\n",
      "Sleep Hours                        \t    16.187\n",
      "Sample Question Papers Practiced   \t    16.188\n"
     ]
    }
   ],
   "source": [
    "# Phần code cho yêu cầu 2b\n",
    "# Tìm ra đặc trưng tốt nhất (trong 5 đặc trưng)\n",
    "k = 5 \n",
    "kf = KFold(n_splits=k, shuffle=True, random_state=42)\n",
    "\n",
    "mae_per_feature = []\n",
    "# K-Fold Cross-Validation\n",
    "for feature in features:\n",
    "    X_train_feature = train[feature].to_numpy()\n",
    "    X_train_feature = X_train_feature.reshape(-1,1)\n",
    "    mae_per_fold = 0\n",
    "    for fold, (train_index, val_index) in enumerate(kf.split(X_train_feature)):\n",
    "        # split\n",
    "        X_train_fold, X_val_fold = X_train_feature[train_index], X_train_feature[val_index]\n",
    "        y_train_fold, y_val_fold = y_train[train_index], y_train[val_index]\n",
    "        XbarFold = np.concatenate((np.ones((X_train_fold.shape[0],1)),X_train_fold), axis = 1)\n",
    "        # LR + pred\n",
    "        wFold = LinearRegression(XbarFold,y_train_fold)\n",
    "        y_pred_fold = predict(wFold,np.concatenate((np.ones((X_val_fold.shape[0],1)),X_val_fold), axis = 1))\n",
    "\n",
    "        mae_per_fold += mean_absolute_error(y_pred=y_pred_fold, y_true=y_val_fold)\n",
    "    mae_per_feature.append(mae_per_fold/k)\n",
    "\n",
    "print(f\"{'Feature': <35} {'MAE':>10}\")\n",
    "for i in range(len(features)):\n",
    "    print(f\"{features[i]:<35}\\t{mae_per_feature[i]:>10.3f}\")    "
   ]
  },
