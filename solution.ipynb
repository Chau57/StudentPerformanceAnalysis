     ]
    }
   ],
   "source": [
    "# Phần code cho yêu cầu 2a\n",
    "one = np.ones((X_train.shape[0],1))\n",
    "Xbar = np.concatenate((one, X_train), axis = 1)\n",
    "w = LinearRegression(Xbar,y_train)\n",
    "\n",
    "expression = f\"{np.round(w[0],3)} + \" + \" + \".join(\n",
    "    [f\"{np.round(w[i+1],3)} * {features[i]}\" for i in range(len(features))]\n",
    ")\n",
    "\n",
    "print(\"Biểu thức hồi quy tuyến tính:\")\n",
    "print(\"y_hat =\", expression)\n",
    "x_test = np.concatenate((np.ones((X_test.shape[0],1)), X_test), axis =1)\n",
    "\n",
    "y_predict = predict(w,x_test)"
   ]
